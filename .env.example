# ─────────────────────────────────────────────
#  Malwas CCA — Environment Variables
#  Copy this file to .env.local and fill in values
#  NEVER commit .env.local to version control
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NEXT_PUBLIC_SITE_NAME="Malwas CCA"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_DESCRIPTION="Premium Car Accessories & Modification — Ranchi Road, Near Hyundai Showroom"

# ── Contact Info (public — shown in UI) ──────
NEXT_PUBLIC_PHONE="+91 9798646302"
NEXT_PUBLIC_WHATSAPP="919798646302"
NEXT_PUBLIC_EMAIL="info@Malwascca.in"
NEXT_PUBLIC_ADDRESS="Ranchi Road, Near Hyundai Showroom, Jharkhand"
NEXT_PUBLIC_GOOGLE_MAPS_LINK="https://maps.google.com/?q=Ranchi+Road+Hyundai+Showroom"

# ── Database (if using Prisma / MongoDB / Supabase) ──
DATABASE_URL="mongodb+srv://user:password@cluster.mongodb.net/Malwas-cca?retryWrites=true&w=majority"
# DATABASE_URL="postgresql://user:password@localhost:5432/Malwas_cca"

# ── Authentication (NextAuth.js) ──────────────
NEXTAUTH_SECRET="replace-with-a-strong-random-secret-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# ── Payment Gateway ───────────────────────────
# Razorpay
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# PhonePe / PayU (alternative)
# PHONEPE_MERCHANT_ID="MalwasCCA"
# PHONEPE_SALT_KEY="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# PHONEPE_SALT_INDEX="1"

# ── Email (Nodemailer / Resend / SendGrid) ────
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="noreply@Malwascca.in"

# Resend (alternative)
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Storage (Cloudinary / AWS S3) ─────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="000000000000000"
CLOUDINARY_API_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="Malwas-cca-unsigned"

# AWS S3 (alternative)
# AWS_ACCESS_KEY_ID="AKIAXXXXXXXXXXXXXXXX"
# AWS_SECRET_ACCESS_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# AWS_REGION="ap-south-1"
# AWS_S3_BUCKET="Malwas-cca-assets"

# ── Google Analytics / GTM ────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"

# ── WhatsApp Business API (optional) ─────────
# WHATSAPP_API_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# WHATSAPP_PHONE_NUMBER_ID="000000000000000"

# ── Misc ──────────────────────────────────────
NODE_ENV="development"
