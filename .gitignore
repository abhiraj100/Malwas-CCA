# ─────────────────────────────────────────────
#  Malwas CCA — .gitignore
# ─────────────────────────────────────────────

# ── Environment variables (NEVER commit) ─────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# ── Next.js ───────────────────────────────────
.next/
out/
build/

# ── Node ──────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm

# ── Package manager locks (keep only one) ────
# Uncomment the one you DON'T use:
# package-lock.json   # if using yarn / pnpm
# yarn.lock           # if using npm / pnpm
# pnpm-lock.yaml      # if using npm / yarn

# ── TypeScript ────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Testing ───────────────────────────────────
coverage/
.nyc_output/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# ── Editors & IDEs ────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────
logs/
*.log
lerna-debug.log*

# ── Runtime / cache ───────────────────────────
.cache/
.parcel-cache/
.turbo/
.vercel/
.netlify/

# ── Uploads / user generated content ─────────
public/uploads/
public/media/

# ── Database ─────────────────────────────────
*.sqlite
*.sqlite3
*.db
prisma/migrations/

# ── Misc ──────────────────────────────────────
*.pem
*.key
*.cert
dist/
tmp/
temp/
